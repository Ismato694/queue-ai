# Queue.ai — environment template. Copy to .env.local (web) / .env (worker). NEVER commit real values.

# ── Supabase (create a project in the af-south-1 / Cape Town region for NDPR residency) ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # worker only — bypasses RLS, keep secret

# ── Claude (Flow Intelligence) ──
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_HARD=claude-opus-4-8
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5

# ── Embeddings (RAG) — Voyage (Claude does not embed) ──
VOYAGE_API_KEY=

# ── Notifications (Africa-native) ──
TERMII_API_KEY=
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
RESEND_API_KEY=

# ── Maps ──
GOOGLE_MAPS_API_KEY=

# ── Worker ──
WORKER_PORT=4000
