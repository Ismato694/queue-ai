# Queue.ai — environment template. Copy to .env.local (web) / .env (worker). NEVER commit real values.

# ── Supabase (create a project in the af-south-1 / Cape Town region for NDPR residency) ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # worker only — bypasses RLS, keep secret

# ── Claude (Flow Intelligence) ──
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_HARD=claude-opus-4-8
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5

# ── Embeddings (RAG) — Voyage (Claude does not embed) ──
VOYAGE_API_KEY=

# ── Notifications (Africa-native) ──
TERMII_API_KEY=
TERMII_SENDER_ID=Queue.ai          # approved alphanumeric sender ID
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
RESEND_API_KEY=

# ── WhatsApp join channel (Meta WhatsApp Cloud API) ──
WHATSAPP_TOKEN=                     # Graph API access token (web webhook + worker outbound)
WHATSAPP_PHONE_NUMBER_ID=          # your WhatsApp Business phone-number ID
WHATSAPP_VERIFY_TOKEN=queue-ai     # arbitrary string; must match the value set in Meta webhook config
NEXT_PUBLIC_WHATSAPP_NUMBER=       # E.164 w/o '+', powers the wa.me "Join on WhatsApp" CTA

# ── App URL (used in WhatsApp replies for the live tracker link) ──
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# ── Maps ──
GOOGLE_MAPS_API_KEY=

# ── Worker ──
WORKER_PORT=4000
