{
  "name": "queue-ai",
  "private": true,
  "version": "0.0.1",
  "description": "Queue.ai — AI-powered Customer Flow Operating System (MVP: Nigerian private hospitals)",
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:worker": "npm --workspace services/worker run dev",
    "build": "npm --workspaces --if-present run build",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "test": "npm --workspaces --if-present run test",
    "lint": "npm --workspaces --if-present run lint",
    "db:reset": "echo 'Run: supabase db reset (applies supabase/migrations + seed.sql)'"
  },
  "engines": {
    "node": ">=20"
  }
}
